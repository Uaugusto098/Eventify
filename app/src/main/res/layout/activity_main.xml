<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/AzulEscuro"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center_horizontal"
    >

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="128dp"
        android:layout_height="102dp"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        app:srcCompat="@drawable/logoapp" />

    <TextView
        android:id="@+id/txtBemVindo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Bem-vindo"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/txtSubtitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Gerencie seus eventos com facilidade"
        android:textColor="#8AAAC8"
        android:textSize="14sp" />

    <View
        android:layout_width="60dp"
        android:layout_height="1dp"
        android:layout_marginTop="28dp"
        android:background="#2A4060" />

    <android.widget.Button
        android:id="@+id/cadastrarEventos"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="40dp"
        android:background="@drawable/botaoazulg"
        android:text="Cadastrar Evento"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

    <android.widget.Button
        android:id="@+id/listarEventos"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="14dp"
        android:background="@drawable/botaoazulg"
        android:text="Listar Eventos"
        android:textColor="#FAFAFA"
        android:textStyle="bold" />

</LinearLayout>